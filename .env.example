# Copie este arquivo para .env (que já está no .gitignore) e preencha os valores.
# Em produção, os mesmos nomes viram Secrets no GitHub (Settings > Secrets and variables > Actions).

BLING_CLIENT_ID=
BLING_CLIENT_SECRET=
BLING_REFRESH_TOKEN=
BLING_DEPOSITO_ID= # id do depósito "SITE / MERCADO LIVRE" no Bling (Cadastros > Depósitos)

ML_CLIENT_ID=
ML_CLIENT_SECRET=
ML_REFRESH_TOKEN=
ML_SELLER_ID=

# Opcionais (alerta de risco de furo, quando Bling < ML) — deixe em branco
# pra pular. Tenta nessa ordem: CallMeBot -> Z-API -> e-mail via Gmail.

# CallMeBot é grátis: manda "I allow callmebot to send me messages" pro
# +34 644 44 21 48 no WhatsApp e ele responde com a API key.
CALLMEBOT_PHONE=
CALLMEBOT_APIKEY=

# Alternativa paga ao CallMeBot
ZAPI_INSTANCE_URL=
WHATSAPP_DESTINO=

# E-mail via Gmail (grátis) — GMAIL_APP_PASSWORD é a "senha de app" de 16
# caracteres gerada em myaccount.google.com/apppasswords, não a senha normal.
GMAIL_USER=
GMAIL_APP_PASSWORD=
EMAIL_DESTINO=

# Só necessário no GitHub Actions, pra girar os refresh tokens automaticamente
GH_PAT=
