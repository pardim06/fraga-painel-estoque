# Copie este arquivo para .env (que já está no .gitignore) e preencha os valores.
# Em produção, os mesmos nomes viram Secrets no GitHub (Settings > Secrets and variables > Actions).

BLING_CLIENT_ID=
BLING_CLIENT_SECRET=
BLING_REFRESH_TOKEN=
BLING_DEPOSITO_ID= # id do depósito "SITE / MERCADO LIVRE" no Bling (Cadastros > Depósitos)

ML_CLIENT_ID=
ML_CLIENT_SECRET=
ML_REFRESH_TOKEN=
ML_SELLER_ID=

# Opcionais (alerta de WhatsApp via Z-API) — deixe em branco pra pular
ZAPI_INSTANCE_URL=
WHATSAPP_DESTINO=

# Só necessário no GitHub Actions, pra girar os refresh tokens automaticamente
GH_PAT=
